          key\n              prompt\n              promptVersion\n              value\n              useCustomPrompt\n              prompts {\n                prompt\n                version\n                createdAt\n                createdBy {\n                  id\n                  firstName\n                  lastName\n                }\n              }\n              occurrences {\n                after\n                before\n              }\n            }\n          }\n        }\n        pageInfo {\n          endCursor\n          hasNextPage\n          hasPreviousPage\n          startCursor\n        }\n        totalCount\n      }\n    }\n  }\n":no,"\n  mutation createSowTemplate($input: CreateSOWTemplateInput!) {\n    createSOWTemplate(input: $input) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        id\n        name\n      }\n    }\n  }\n":nl,"\n  mutation deleteSowTemplate($templateId: ID!) {\n    deleteSOWTemplate(id: $templateId) {\n      success\n      errors {\n        code\n        message\n      }\n    }\n  }\n":nd,"\n  query getSowDocument($id: ID!) {\n    sowDocument(id: $id) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        id\n        name\n        status\n        downloadUrl\n        isOutdated\n        updatedAt\n        createdAt\n        errorMessage\n        templateId\n        variables {\n          key\n          prompt\n          promptVersion\n          value\n          occurrences {\n            before\n            after\n          }\n          prompts {\n            prompt\n            version\n            createdAt\n            createdBy {\n              id\n              firstName\n              lastName\n            }\n          }\n          useCustomPrompt\n        }\n      }\n    }\n  }\n":nu,"\n  query getSowDocuments($input: SOWDocumentsInput!) {\n    sowDocuments(input: $input) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        edges {\n          cursor\n          node {\n            id\n            name\n            status\n            downloadUrl\n            isOutdated\n            templateId\n            variables {\n              key\n              prompt\n              promptVersion\n              value\n              occurrences {\n                before\n                after\n              }\n              prompts {\n                prompt\n                version\n                createdAt\n                createdBy {\n                  id\n                  firstName\n                  lastName\n                }\n              }\n              useCustomPrompt\n            }\n            createdAt\n            createdBy\n            updatedAt\n            updatedBy\n          }\n        }\n        pageInfo {\n          endCursor\n          hasNextPage\n          hasPreviousPage\n          startCursor\n          totalCount\n        }\n        totalCount\n      }\n    }\n  }\n":nc,"\n  mutation generateSowDocument($id: ID!) {\n    generateSOWDocument(id: $id) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        id\n        name\n        status\n        downloadUrl\n        updatedAt\n        isOutdated\n        variables {\n          key\n          prompt\n          value\n        }\n      }\n    }\n  }\n":np,"\n  mutation sendSOWDocumentEmail($input: SendSOWDocumentEmailInput!) {\n    sendSOWDocumentEmail(input: $input) {\n      data {\n        downloadUrl\n        id\n        name\n        status\n        createdAt\n        updatedAt\n        isOutdated\n        variables {\n          key\n          prompt\n          value\n        }\n      }\n      errors {\n        code\n        message\n      }\n      success\n    }\n  }\n":nm,"\n  mutation archiveSOWDocument($id: ID!) {\n    archiveSOWDocument(id: $id) {\n      errors {\n        code\n        message\n      }\n      success\n    }\n  }\n":ng,"\n  mutation createSowDocument($input: CreateSOWDocumentInput!) {\n    createSOWDocument(input: $input) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        id\n        name\n        status\n        downloadUrl\n        updatedAt\n        isOutdated\n        variables {\n          key\n          prompt\n          value\n        }\n      }\n    }\n  }\n":nS,"\n  mutation updateSowDocument($input: UpdateSOWDocumentInput!) {\n    updateSOWDocument(input: $input) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        id\n        name\n        status\n        downloadUrl\n        updatedAt\n        isOutdated\n        variables {\n          key\n          prompt\n          value\n        }\n      }\n    }\n  }\n":nI,"\n  mutation uploadSowTranscript($input: UploadSOWTranscriptInput!) {\n    uploadSOWTranscript(input: $input) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        presignedUrl\n      }\n    }\n  }\n":ny,"\n  mutation uploadSowTemplate($input: UploadSOWTemplateInput!) {\n    uploadSOWTemplate(input: $input) {\n      success\n      errors {\n        code\n        message\n      }\n      data {\n        presignedUrl\n      }\n    }\n  }\n":nf,"\n  mutation useCustomPromptForSOWVariable(\n    $input: UseCustomPromptForSOWVariableInput!\n  ) {\n    useCustomPromptForSOWVariable(input: $input) {\n      data {\n        useCustomPrompt\n      }\n      errors {\n        code\n        message\n      }\n      success\n    }\n  }\n":nA,"\n  mutation addSOWVariablePrompt($input: AddSOWVariablePromptInput!) {\n    addSOWVariablePrompt(input: $input) {\n      data {\n        prompt\n      }\n    }\n  }\n":nU,"\n  mutation testSOWVariablePrompt($input: TestSOWVariablePromptInput!) {\n    testSOWVariablePrompt(input: $input) {\n      data {\n        generatedValue\n      }\n      errors {\n        code\n        message\n      }\n      success\n    }\n  }\n":nE,"\n  mutation setActiveSOWVariablePromptVersion(\n    $input: SetActiveSOWVariablePromptVersionInput!\n  ) {\n    setActiveSOWVariablePromptVersion(input: $input) {\n      data {\n        prompt\n      }\n      errors {\n        code\n        message\n      }\n      success\n    }\n  }\n":nC,"\n  mutation deleteSOWVariableCustomPrompt(\n    $input: DeleteSOWVariableCustomPromptInput!\n  ) {\n    deleteSOWVariableCustomPrompt(input: $input) {\n      errors {\n        code\n        message\n      }\n      message\n      success\n    }\n  }\n":nb,"\n  query getUniversities {\n    getUniversities {\n      count\n      university_objects {\n        name\n      }\n    }\n  }\n":nh,"\n  fragment UserFields on User {\n    id\n    firstName\n    lastName\n    email\n    username\n    avatarURL\n    joinedAt\n    signUpSource\n    latestAcceptedLegalDocuments {\n      entryId\n      documentType\n      version\n    }\n    notificationSettings {\n      subscribedToUpdates\n    }\n    termsAccepted\n    termsAcceptedDate\n    emailOptIn\n    lastMfaTime\n    signedUpForInterview\n    subscriptions\n    updatedAt\n  }\n":D,"\n  fragment AwardFields on Award {\n    id\n    title\n    type\n    receivedAt\n  }\n":$,"\n  fragment LeaderboardInfoFields on LeaderboardHit {\n    id\n    rank\n    score\n    username\n    bestRank\n    percentile\n    memberSince\n    username\n    avatarUrl\n  }\n":v,"\n  fragment UserExperienceFields on UserExperience {\n    energyBackgrounds {\n      basins {\n        id\n        name\n      }\n      industry\n    }\n    regionalBackgrounds {\n      region\n    }\n    scienceBackgrounds {\n      type\n    }\n    softwareBackgrounds {\n      type\n    }\n  }\n":R,"\n  fragment UserProfileFields on UserProfile {\n    id\n    publicProfileId\n    bio\n    completionLevel {\n      percentage\n    }\n    educations {\n      degree\n      endDate\n      institution\n      major\n      startDate\n    }\n    employments {\n      company\n      endDate\n      startDate\n      title\n    }\n    experience {\n      ...UserExperienceFields\n    }\n    gitRepoUrl\n    interests\n    linkedInUrl\n    location {\n      administrativeArea\n      country\n      locality\n    }\n    userId\n  }\n":L,"\n  query getUsersPublicInfo($ids: [ID!]!) {\n    getUsersPublicInfo(ids: $ids) {\n      id\n      email\n      username\n      avatarUrl\n      publicProfileId\n    }\n  }\n":nT,"\n  query getUsers($ids: [ID!]!) {\n    getUsers(ids: $ids) {\n      ...UserFields\n    }\n  }\n":nD,"\n  query userById($userId: ID!) {\n    getUser(id: $userId) {\n      ...UserFields\n      profile {\n        ...UserProfileFields\n      }\n    }\n  }\n":n$,"\n  query publicUserProfileById($userId: ID!) {\n    getUser(id: $userId) {\n      ...UserFields\n      profile {\n        ...UserProfileFields\n        favoritedInLists {\n          id\n          title\n        }\n        internal {\n          tags\n          languageFluency\n          notes\n        }\n        projectsAccepted(input: { pageInfo: { first: 0 } }) {\n          totalCount\n        }\n        projectsApplied(input: { pageInfo: { first: 0 } }) {\n          totalCount\n        }\n      }\n    }\n  }\n":nv,"\n  query userByEmail($email: AWSEmail!) {\n    userByEmail(email: $email) {\n      ...UserFields\n      profile {\n        ...UserProfileFields\n      }\n    }\n  }\n":nR,"\n  query publicUserProfile($publicProfileId: ID!) {\n    publicUserProfile(publicProfileId: $publicProfileId) {\n      data {\n        id\n        awards {\n          ... on Award {\n            ...AwardFields\n          }\n        }\n        experience {\n          ...UserExperienceFields\n        }\n        leaderboardInfo {\n          ...LeaderboardInfoFields\n        }\n        username\n      }\n      errors {\n        message\n        code\n      }\n      success\n    }\n  }\n":nL,"\n  query userMFA($userId: ID!) {\n    getUserMFA(id: $userId) {\n      mfaRequired\n    }\n  }\n":nP,"\n  mutation updateUser($user: UserInput!) {\n    updateUser(user: $user) {\n      __typename\n      ... on UpdateUserSuccess {\n        user {\n          ...UserFields\n        }\n      }\n    }\n  }\n":nO,"\n  mutation deleteUser($id: ID!, $deletedReason: String) {\n    deleteUser(id: $id, deletedReason: $deletedReason) {\n      __typename\n      ... on DeleteUserSuccess {\n        user {\n          firstName\n          id\n          lastName\n        }\n      }\n    }\n  }\n":n_,"\n  mutation updateUserProfile($userProfile: UserProfileInput!) {\n    updateUserProfile(profile: $userProfile) {\n      __typename\n      ... on UpdateUserProfileSuccess {\n        profile {\n          ...UserProfileFields\n        }\n      }\n    }\n  }\n":nw,"\n  mutation acceptLegalDocument($input: AcceptLegalDocumentInput!) {\n    acceptLegalDocument(input: $input) {\n      errors {\n        message\n        code\n      }\n      success\n    }\n  }\n":nk,"\n  query getBasinList {\n    getBasinList {\n      count\n      basins {\n        id\n        name\n        provinceName\n      }\n    }\n  }\n":nN,"\n  query userAvatarUploadUrl {\n    getAvatarUploadUrl {\n      url\n      formFields\n    }\n  }\n":nF,"\n  mutation createUserAndProfile(\n    $id: String!\n    $email: String!\n    $firstName: String!\n    $lastName: String!\n    $username: String!\n    $notificationSettings: UserNotificationSettingsInput!\n  ) {\n    createUserAndProfile(\n      id: $id\n      email: $email\n      firstName: $firstName\n      lastName: $lastName\n      username: $username\n      notificationSettings: $notificationSettings\n    ) {\n      ... on CreateUserAndProfileSuccess {\n        __typename\n        user {\n          ...UserFields\n          profile {\n            ...UserProfileFields\n          }\n        }\n      }\n    }\n  }\n":nB,"\n  mutation subscribeByEmail($email: AWSEmail!, $type: SubscriptionType!) {\n    subscribeByEmail(email: $email, type: $type) {\n      email\n    }\n  }\n":nV,"\n  mutation subscribeUser($id: ID!, $type: SubscriptionType!) {\n    subscribeUser(id: $id, type: $type) {\n      user {\n        id\n      }\n    }\n  }\n":nx,"\n  mutation unsubscribeUser($id: ID!, $type: SubscriptionType!) {\n    unsubscribeUser(id: $id, type: $type) {\n      user {\n        id\n      }\n    }\n  }\n":nj,"\n  mutation optInForInterview($id: ID!, $challengeTeamId: Int!) {\n    optInForInterview(id: $id, challengeTeamId: $challengeTeamId) {\n      msg\n    }\n  }\n":nW,"\n  query getUserWork($userId: ID!, $pageSize: Int!, $status: UserWorkStatus!) {\n    getUserWork(\n      input: { userId: $userId, pageSize: $pageSize, status: $status }\n    ) {\n      projects {\n        id\n        status\n        title\n        externalId\n        userApplication {\n          status\n        }\n        startDate\n      }\n      challenges {\n        id\n        externalId\n        title\n        endDate\n        startDate\n        submissionResult {\n          place\n          score\n        }\n      }\n      bounties {\n        id\n        externalId\n        title\n        startDate\n        userSubmissionInfo {\n          submissionsLeftToday\n        }\n      }\n    }\n  }\n":new b("\n    query getUserWork($userId: ID!, $pageSize: Int!, $status: UserWorkStatus!) {\n  getUserWork(input: {userId: $userId, pageSize: $pageSize, status: $status}) {\n    projects {\n      id\n      status\n      title\n      externalId\n      userApplication {\n        status\n      }\n      startDate\n    }\n    challenges {\n      id\n      externalId\n      title\n      endDate\n      startDate\n      submissionResult {\n        place\n        score\n      }\n    }\n    bounties {\n      id\n      externalId\n      title\n      startDate\n      userSubmissionInfo {\n        submissionsLeftToday\n      }\n    }\n  }\n}\n    "),"\n  query getWorkSummary($input: WorkSummaryFilter) {\n    getWorkSummary(input: $input) {\n      workItemSummaries {\n        type\n        totalNumber\n        totalPrice {\n          amount\n          currencyCode\n        }\n      }\n    }\n  }\n":new b("\n    query getWorkSummary($input: WorkSummaryFilter) {\n  getWorkSummary(input: $input) {\n    workItemSummaries {\n      type\n      totalNumber\n      totalPrice {\n        amount\n        currencyCode\n      }\n    }\n  }\n}\n    ")};function nq(n){var e;return null!=(e=nM[n])?e:{}}nq("\n  query getActiveResources {\n    getActiveResources {\n      bountyBoards\n      challenges\n      projects\n    }\n  }\n").toString(),nq("\n  query getBountyGroupCards(\n    $groupStatuses: [BountyBoardStatus!] = [ACTIVE_STATUS]\n    $bountyStatuses: [BountyStatus!] = [ACTIVE_STATUS]\n  ) {\n    getBountyBoards(\n      input: {\n        filter: {\n          bountyStatuses: $bountyStatuses\n          groupStatuses: $groupStatuses\n        }\n        sort: { bountyOrder: [START_DATE], groupOrder: [START_DATE] }\n      }\n    ) {\n      bountyBoards {\n        id\n        externalId\n        title\n        description\n        startDate\n        endDate\n        price {\n          amount\n          currencyCode\n        }\n        status\n        bounties {\n          externalId\n          status\n          weight\n          shortDescription\n          images {\n            type\n            url\n          }\n          price {\n            amount\n            currencyCode\n          }\n          title\n          # description\n          id\n        }\n        description\n        tags\n        title\n        price {\n          amount\n          currencyCode\n        }\n        id\n      }\n      pageInfo {\n        totalCount\n      }\n    }\n  }\n").toString(),nq("\n  fragment ChallengeFragment on Challenge {\n    compensation {\n      prize {\n        amount\n        currencyCode\n      }\n    }\n    description\n    subtitle\n    slug\n    id\n    images {\n      type\n      url\n    }\n    participationStats {\n      totalTeams\n    }\n    title\n    startDate\n    endDate\n    tags\n    status\n    sandboxMode\n  }\n"),nq("\n  query Challenge($slug: String!) {\n    challenge(slug: $slug) {\n      id\n      slug\n      title\n      description\n      subtitle\n      status\n      startDate\n      endDate\n      sandboxMode\n      type\n      tags\n      categories\n      allowedEmailDomains\n      inviteOnly\n      isFeatured\n      nextChallengeSlug\n      priority\n      teamFormationDeadline\n      weight\n      externalId\n      details {\n        description\n        endDate\n        startDate\n      }\n      price {\n        amount\n        currencyCode\n      }\n      participation {\n        currentUserJoined\n        totalJoinedTeams\n      }\n      images {\n        type\n        url\n      }\n      compensation {\n        prize {\n          amount\n          currencyCode\n        }\n      }\n      participationStats {\n        totalTeams\n      }\n      announcementText {\n        json\n        plainText\n      }\n      dataTabDescription {\n        json\n        plainText\n      }\n      leaderboard {\n        description {\n          json\n          plainText\n        }\n        order\n        threshold\n      }\n      overview {\n        json\n        plainText\n      }\n      resources {\n        forumUrl\n        sponsorUrl\n        starterNotebookUrl\n      }\n      rules {\n        submission {\n          allowedFileTypes\n          maxFileSize\n          maxSubmissions\n          maxSubmissionsDaily\n        }\n      }\n      rulesText {\n        json\n        plainText\n      }\n      scoring {\n        algorithm\n        minimumScore\n      }\n      stages {\n        compensation {\n          prize {\n            amount\n            currencyCode\n          }\n        }\n        description\n        externalId\n        id\n        images {\n          type\n          url\n        }\n        leaderboard {\n          description {\n            json\n            plainText\n          }\n          order\n          threshold\n        }\n        minimumScore\n        status\n        tags\n        title\n        sequence_number\n        price {\n          amount\n          currencyCode\n        }\n      }\n      starterNotebook {\n        downloadUrl\n        githubUrl\n        name\n        size\n      }\n      submissionInstructions {\n        json\n        plainText\n      }\n      submissionSample {\n        downloadUrl\n        githubUrl\n        name\n        size\n      }\n      successMessage {\n        json\n        plainText\n      }\n      testDataSet {\n        downloadUrl\n        githubUrl\n        name\n        size\n      }\n      trainingDataSet {\n        downloadUrl\n        githubUrl\n        name\n        size\n      }\n      userParticipation {\n        hasJoined\n      }\n      userPerformance {\n        ranking\n        score\n      }\n    }\n  }\n").toString(),nq("\n  query AllChallenges(\n    $first: Int\n    $after: String\n    $filter: ChallengeFilterInput\n  ) {\n    allChallenges(first: $first, after: $after, filter: $filter) {\n      edges {\n        node {\n          ...ChallengeFragment\n          userParticipation {\n            hasJoined\n          }\n        }\n      }\n      totalCount\n    }\n  }\n").toString(),nq("\n  query ActiveChallenges(\n    $after: String\n    $filter: ChallengeFilterInput\n    $first: Int\n  ) {\n    activeChallenges(after: $after, filter: $filter, first: $first) {\n      edges {\n        node {\n          ...ChallengeFragment\n        }\n      }\n      totalCount\n    }\n  }\n").toString(),nq("\n  query UpcomingChallenges(\n    $after: String\n    $filter: ChallengeFilterInput\n    $first: Int\n  ) {\n    upcomingChallenges(after: $after, filter: $filter, first: $first) {\n      edges {\n        node {\n          ...ChallengeFragment\n        }\n      }\n      totalCount\n    }\n  }\n").toString(),nq("\n  query CompletedChallenges(\n    $after: String\n    $filter: ChallengeFilterInput\n    $first: Int\n  ) {\n    completedChallenges(